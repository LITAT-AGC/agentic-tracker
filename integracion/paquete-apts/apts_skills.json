{
  "skills": [
    {
      "name": "register_task",
      "description": "Create or resume a task in the project. When backlog_item_id points to an active task in todo, in_progress, or stalled, APTS resumes that task instead of creating a duplicate.",
      "parameters": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "project_url": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "agent_name": {
                "type": "string"
              },
              "agent_email": {
                "type": "string"
              },
              "context": {
                "type": "string"
              },
              "backlog_item_id": {
                "type": "string"
              }
            },
            "required": [
              "project_url",
              "title",
              "agent_name",
              "agent_email"
            ]
          },
          {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "project_url": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "agent_name": {
                  "type": "string"
                },
                "agent_email": {
                  "type": "string"
                },
                "context": {
                  "type": "string"
                },
                "backlog_item_id": {
                  "type": "string"
                }
              },
              "required": [
                "project_url",
                "title",
                "agent_name",
                "agent_email"
              ]
            }
          }
        ]
      }
    },
    {
      "name": "read_project_context",
      "description": "Read current project state, backlog items, pending tasks, and recent history.",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "limit": {
            "type": "number",
            "default": 5
          },
          "backlog_status": {
            "type": "string",
            "enum": [
              "draft",
              "needs_details",
              "ready",
              "in_progress",
              "review",
              "blocked",
              "done",
              "archived"
            ]
          }
        },
        "required": [
          "url"
        ]
      }
    },
    {
      "name": "list_backlog_items",
      "description": "List backlog items for a project ordered by priority and sort order. Use this before direct implementation to detect whether a reported bug, error, or regression is already tracked.",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "needs_details",
              "ready",
              "in_progress",
              "review",
              "blocked",
              "done",
              "archived"
            ]
          },
          "include_deleted": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "url"
        ]
      }
    },
