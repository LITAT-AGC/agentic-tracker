              "ready",
              "in_progress",
              "review",
              "blocked",
              "done",
              "archived"
            ]
          },
          "include_deleted": {
            "type": "boolean",
            "default": false
          }
        },
        "required": []
      }
    },
    {
      "name": "search_similar_bug_reports",
