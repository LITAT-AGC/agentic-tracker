{
  "skills": [
    {
      "name": "register_task",
      "description": "Create or resume a task in the project. Minimum payload in official client/CLI: title (project_url, agent_name, and agent_email are auto-resolved from env/local managed context/Git when omitted). When backlog_item_id points to an active task in todo, in_progress, or stalled, APTS resumes that task instead of creating a duplicate.",
      "parameters": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "project_url": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "agent_name": {
                "type": "string"
              },
              "agent_email": {
                "type": "string"
              },
              "context": {
                "type": "string"
              },
              "backlog_item_id": {
                "type": "string"
              }
            },
            "required": [
              "title"
            ]
          },
          {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "project_url": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "agent_name": {
                  "type": "string"
                },
                "agent_email": {
                  "type": "string"
                },
                "context": {
                  "type": "string"
                },
                "backlog_item_id": {
                  "type": "string"
                }
              },
              "required": [
                "title"
              ]
            }
          }
        ]
      }
    },
    {
      "name": "read_project_context",
      "description": "Read current project state, backlog items, pending tasks, and recent history. Minimum payload in official client/CLI: none for identity (url auto-resolves from env/local managed context/Git when omitted). Optional: limit and backlog_status.",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "limit": {
            "type": "number",
            "default": 5
          },
          "backlog_status": {
            "type": "string",
            "enum": [
              "draft",
              "needs_details",
              "ready",
              "in_progress",
              "review",
              "blocked",
              "done",
              "archived"
            ]
          }
        },
        "required": []
      }
    },
    {
      "name": "list_backlog_items",
      "description": "List backlog items for a project ordered by priority and sort order. Minimum payload in official client/CLI: none for identity (url auto-resolves from env/local managed context/Git when omitted). Use this before direct implementation to detect whether a reported bug, error, or regression is already tracked.",
